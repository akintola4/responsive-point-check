{
  "name": "res-point-check",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome extension to preview any URL across multiple device viewports",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "compile": "tsc --noEmit",
    "screenshot": "wxt build && tsx scripts/screenshot-devices.ts",
    "postinstall": "wxt prepare && node scripts/extract-geist-assets.mjs"
  },
  "dependencies": {
    "geist": "^1.5.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.281",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "wxt": "^0.20.0"
  }
}
